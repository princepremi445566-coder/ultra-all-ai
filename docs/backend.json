{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user profile information.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt"]
    },
    "ToolUsageLog": {
      "title": "ToolUsageLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "toolName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "inputData": { "type": "string" },
        "outputResult": { "type": "string" }
      },
      "required": ["id", "userId", "toolName", "timestamp", "inputData", "outputResult"]
    }
  },
  "auth": {
    "providers": ["password", "google.com", "phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" }
        }
      },
      {
        "path": "/users/{userId}/toolUsageLogs/{logId}",
        "definition": {
          "entityName": "ToolUsageLog",
          "schema": { "$ref": "#/backend/entities/ToolUsageLog" }
        }
      }
    ]
  }
}
