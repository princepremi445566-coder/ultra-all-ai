rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model designed for the "Ultra All AI" platform. 
     * Access is governed primarily by path-based authorization, where a user's identity (UID) 
     * must match the identifiers present in the document path.
     *
     * DATA STRUCTURE:
     * The database follows a hierarchical, user-centric structure:
     * - /users/{userId}: Private user profile data.
     * - /users/{userId}/toolUsageLogs/{logId}: Private history of AI tool interactions.
     *
     * KEY SECURITY DECISIONS:
     * - Ownership-Only Access: Users can only read, list, or modify data within their own 
     *   dedicated path (/users/auth.uid/...). Public listing of users or logs is strictly prohibited.
     * - Path-Based Authorization: By embedding the owner's UID directly in the document path, 
     *   we eliminate the need for costly get() lookups, ensuring rules are fast and atomic.
     * - Relational Integrity: On document creation and update, rules verify that internal 
     *   foreign key fields (like 'userId' or 'id') remain consistent with the document's 
     *   location and identity, preventing data spoofing.
     *
     * DENORMALIZATION FOR AUTHORIZATION:
     * To ensure authorization decisions are independent and performant:
     * - The 'userId' is denormalized both into the document path and as a field within 
     *   the document (e.g., ToolUsageLog.userId). This allows for Query-Aware Permissions (QAPs) 
     *   where the client simply queries their own subcollection path.
     *
     * STRUCTURAL SEGREGATION:
     * Private user data is kept entirely separate from any potentially public collections 
     * by nesting all sensitive entities under the /users/{userId} prefix.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document currently exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for individual UserProfile documents.
     * @path /users/{userId}
     * @allow (get) If auth.uid == userId.
     * @deny (list) If auth.uid != userId (Prevents user enumeration).
     * @principle Restricts profile access to the document owner and ensures relational consistency.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      
      // On create, ensure the internal 'id' matches the document path/auth UID.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      
      // On update, ensure the document exists and the 'id' field remains immutable.
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for a user's historical AI tool usage logs.
       * @path /users/{userId}/toolUsageLogs/{toolUsageLogId}
       * @allow (create) If auth.uid == userId and data.userId == userId.
       * @deny (get) If auth.uid does not match the parent userId path.
       * @principle Uses path-based authorization to secure private subcollections without extra reads.
       */
      match /toolUsageLogs/{toolUsageLogId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        
        // On create, ensure the internal 'userId' matches the parent path/auth UID.
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        
        // On update, ensure the document exists and the 'userId' field remains immutable.
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        
        allow delete: if isExistingOwner(userId);
      }
    }

  }
}